{
  "name": "live-quiz-game",
  "version": "1.0.0",
  "description": "Real-time Live Quiz Game with WebSocket",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "start": "concurrently \"npm run start:client\" \"npm run start:server\"",
    "start:client": "npm run dev --workspace=client -- --host --port 5173",
    "start:server": "npm run start --workspace=server",
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "install:all": "npm install && npm install --workspace=server && npm install --workspace=client"
  },
  "keywords": [
    "websocket",
    "quiz",
    "game",
    "real-time"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
